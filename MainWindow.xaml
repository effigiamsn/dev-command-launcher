<Window
    x:Class="DevCommandLauncherApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <NavigationView
        x:Name="RootNavigation"
        PaneTitle="Dev Command Launcher"
        OpenPaneLength="220"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Dashboard" Icon="Play" Tag="Dashboard" />
            <NavigationViewItem Content="Settings" Icon="Setting" Tag="Settings" />
            <NavigationViewItem Content="Logs" Icon="Document" Tag="Logs" />
        </NavigationView.MenuItems>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="28,22,28,10" Spacing="4">
                <TextBlock Text="Dev Command Launcher" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Local development command manager" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Frame x:Name="ContentFrame" Grid.Row="1" />

            <Border Grid.Row="2" Padding="16,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
        </Grid>
    </NavigationView>
</Window>
